  "original" : "I'm not lookin' for a love affair...",
  "traduzido" : "Eu não procuro um romance...",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 345,
  "estilo" : "Karaoke Simples",
  "original" : "I need the magic when I hold you near!",
  "traduzido" : "Eu preciso da magia quando te seguro perto de mim!",
