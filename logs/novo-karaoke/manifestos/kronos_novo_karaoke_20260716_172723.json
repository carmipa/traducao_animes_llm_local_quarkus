    "linhasCriadas" : [ {
      "inicio" : "0:00:52.15",
      "fim" : "0:01:04.12",
      "texto" : "Lt. Comandante Cima!",
      "eventosOrigem" : 2,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:00:58.28",
      "fim" : "0:01:04.12",
      "texto" : "Que pesadelo persiste!",
      "eventosOrigem" : 1,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:01:04.12",
      "fim" : "0:01:09.50",
      "texto" : "Não preciso, não preciso mais de ontem.",
      "eventosOrigem" : 1,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:01:10.09",
      "fim" : "0:01:15.63",
      "texto" : "É tarde demais para lamentações!",
      "eventosOrigem" : 1,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:01:15.63",
      "fim" : "0:01:18.72",
      "texto" : "I got a burning heart!",
      "eventosOrigem" : 2,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:01:18.72",
      "fim" : "0:01:27.64",
      "texto" : "Eu só quero continuar correndo! Apenas perseguindo a emoção que está disparando no meu coração!",
      "eventosOrigem" : 1,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:01:28.56",
      "fim" : "0:01:32.61",
      "texto" : "Estações de batalha! Estações de batalha!",
      "eventosOrigem" : 1,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:01:34.61",
      "fim" : "0:01:39.91",
      "texto" : "Fique de olhos bem abertos!",
      "eventosOrigem" : 1,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:01:40.74",
      "fim" : "0:01:42.99",
      "texto" : "I got a burning love!",
      "eventosOrigem" : 2,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:01:43.74",
      "fim" : "0:01:51.88",
      "texto" : "Queimando com fogo azul brilhante. Fogo que se espalhará até cobrir todas as estrelas do céu.",
      "eventosOrigem" : 1,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:01:52.84",
      "fim" : "0:01:55.51",
      "texto" : "I got a burning heart!",
      "eventosOrigem" : 2,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:01:55.92",
      "fim" : "0:02:05.22",
      "texto" : "Lt. Comandante Cima!",
      "eventosOrigem" : 1,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:25:16.20",
      "fim" : "0:25:21.24",
      "texto" : "Don't come to me just 'cause you're lonely tonight...",
      "eventosOrigem" : 2,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:25:21.24",
      "fim" : "0:25:25.87",
      "texto" : "Lonely's only part of your game...",
      "eventosOrigem" : 2,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:25:26.25",
      "fim" : "0:25:31.67",
      "texto" : "As long as you live, you must remember one thing...",
      "eventosOrigem" : 2,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:25:31.67",
      "fim" : "0:25:36.45",
      "texto" : "Give and take are one and the same...",
      "eventosOrigem" : 2,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:25:36.45",
      "fim" : "0:25:39.02",
      "texto" : "So tell me are you ready?",
      "eventosOrigem" : 2,
      "variantesTexto" : 1
    }, {
      "inicio" : "0:25:39.02",
